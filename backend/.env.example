# 服务配置
PORT=3000
NODE_ENV=development

# MySQL 数据库
# Docker 环境下 DB_HOST/REDIS_HOST 由 docker-compose.yml 的 environment 覆盖为服务名
# 本地直接运行时改回 localhost
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=photo_restore

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 阿里云 OSS
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=your_bucket_name
OSS_DOMAIN=https://your_bucket.oss-cn-hangzhou.aliyuncs.com

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# 微信小程序
WECHAT_APP_ID=your_wechat_appid
WECHAT_APP_SECRET=your_wechat_secret
WECHAT_MCH_ID=your_mch_id
WECHAT_MCH_KEY=your_mch_key
WECHAT_NOTIFY_URL=https://your-domain.com/api/callback/wechat

# 抖音小程序
DOUYIN_APP_ID=your_douyin_appid
DOUYIN_APP_SECRET=your_douyin_secret
DOUYIN_NOTIFY_URL=https://your-domain.com/api/callback/douyin

# JWT 密钥
JWT_SECRET=your_jwt_secret_at_least_32_chars

# 积分配置（OpenAI 成本约 ¥0.3/张，定价留出利润）
CREDITS_FREE_ON_REGISTER=3
CREDITS_COST_NORMAL=1
CREDITS_COST_HD=2
